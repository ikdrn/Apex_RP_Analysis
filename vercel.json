{
  "version": 2,
  "builds": [
    {
      "src": "api/get-rp.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/apex-rp-analysis/browser"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/get-rp",
      "dest": "api/get-rp.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
